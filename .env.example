# Intelli-Credit Decisioning Engine
# Environment Configuration

# Ollama (default LLM provider)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_PRIMARY_MODEL=llama3.2:latest
OLLAMA_SECONDARY_MODEL=lfm2.5-thinking:1.2b

# Optional: Cloud LLM APIs
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Optional: Web Search
# SEARCH_API_KEY=
# SEARCH_ENGINE_ID=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
